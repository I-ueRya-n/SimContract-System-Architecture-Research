# SimContract LLM configuration — copy to `.env` and fill in.
# `.env` is git-ignored; never commit real API keys.
#
# Any OpenAI-compatible chat endpoint works: a local LM Studio / Ollama /
# llama.cpp server, or a hosted provider. When these are unset, the LLM
# controllers (bounded_llm / free_llm) stay disabled and degrade observably
# (structured llm_disabled events); everything else runs deterministically.

SIMCONTRACT_LLM_BASE_URL=http://localhost:1234/v1
SIMCONTRACT_LLM_MODEL=your-model-id
SIMCONTRACT_LLM_API_KEY=lm-studio
SIMCONTRACT_LLM_MAX_TOKENS=256
